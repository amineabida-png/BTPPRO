# Copié automatiquement par Railway quand tu ajoutes un service PostgreSQL :
DATABASE_URL=postgresql://user:password@host:5432/railway

# À définir toi-même dans Railway → Variables :
JWT_SECRET=remplace-par-une-chaine-longue-et-aleatoire
ADMIN_EMAIL=admin@btppro.ma
ADMIN_PASSWORD=btppro2026

# Optionnel : mettre true seulement pour une connexion PostgreSQL externe (SSL)
DATABASE_SSL=false
# PORT est fourni automatiquement par Railway.
